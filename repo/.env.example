# Backend
PORT=8080
DATABASE_URL=postgres://medops:medops@localhost:5432/medops?sslmode=disable

# REQUIRED — generate strong random values before deploying; the app will not start without these.
# Example (openssl): openssl rand -hex 32
JWT_SECRET=<REPLACE_WITH_RANDOM_256BIT_SECRET>
# MUST be exactly 32 characters for AES-256 (openssl rand -hex 16)
ENCRYPT_KEY=<REPLACE_WITH_32_CHAR_AES256_KEY>
# Example (openssl): openssl rand -hex 32
HMAC_SIGNING_KEY=<REPLACE_WITH_RANDOM_HMAC_SECRET>

LOG_LEVEL=info
DATA_DIR=/data/medops

# Database
POSTGRES_DB=medops
POSTGRES_USER=medops
POSTGRES_PASSWORD=<REPLACE_WITH_STRONG_DB_PASSWORD>
